# Скопируйте этот файл в .env и заполните.
#
#   cp .env.example .env && nano .env

# Публичный хост релея — для него Caddy выпустит TLS-сертификат.
# Без своего домена возьмите бесплатный sslip.io: <IP-сервера-с-точками>.sslip.io
# Пример: сервер 203.0.113.7  ->  203.0.113.7.sslip.io
RELAY_HOST=203.0.113.7.sslip.io

# Как этот релей анонсирует себя в общий каталог (обычно wss://<RELAY_HOST>).
RELAY_SELF_URL=wss://203.0.113.7.sslip.io

# СОСЕДИ (peers) — здесь указываете уже работающий релей, чтобы влиться в сеть.
# Через запятую можно несколько.
#   • ПЕРВЫЙ релей в сети — оставьте ПУСТЫМ (ему не к кому подключаться).
#   • Каждый следующий — впишите адрес любого живого релея.
RELAY_PEERS=wss://89.108.83.230.sslip.io

# --- Звонки (необязательно, только с профилем "calls") ----------------------
# docker compose --profile calls up -d
# TURN_SECRET — любая длинная случайная строка; TURN_HOST — публичный IP сервера.
TURN_SECRET=
TURN_HOST=
