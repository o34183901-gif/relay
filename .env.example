# Конфигурация релея «Лично». relay-install.sh заполняет обязательные поля и
# генерирует секреты сам — руками править не обязательно.

# --- Обязательное (подставляет установщик) ---
# Домен (A-запись на этот сервер) или <публичный-IP>.sslip.io — авто-TLS через Caddy.
RELAY_HOST=
# Публичный адрес этого релея (обычно wss://<RELAY_HOST>).
RELAY_SELF_URL=

# --- TURN для звонков (генерируется установщиком) ---
TURN_HOST=
TURN_SECRET=

# --- Сеть релеев (необязательно) ---
# Стартовые соседи через запятую: wss://a.example.com,wss://b.example.com
RELAY_PEERS=
# Общий токен федерации для HTTP-gossip МЕЖДУ ВАШИМИ релеями (генерируется).
# Без него анонимный HTTP-gossip выключен (безопасно): узлы находят друг друга
# через pull-gossip и WS-анонс.
RELAY_GOSSIP_TOKEN=

# --- Эксплуатация (необязательно) ---
# Токен для /metrics (генерируется). Без него эндпоинт открыт всем.
RELAY_METRICS_TOKEN=
# Байтовый потолок очереди недоставленного (по умолчанию 8 ГБ). Поднимите под диск.
RELAY_MAX_QUEUE_BYTES=8589934592
