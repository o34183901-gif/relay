# Скопируйте этот файл в .env и заполните.
#
#   cp .env.example .env && nano .env

# Публичный хост релея — для него Caddy выпустит TLS-сертификат.
# Без своего домена возьмите бесплатный sslip.io: <IP-сервера-с-точками>.sslip.io
# Пример: сервер 203.0.113.7  ->  203.0.113.7.sslip.io
RELAY_HOST=203.0.113.7.sslip.io

# Как этот релей анонсирует себя в общий каталог (обычно wss://<RELAY_HOST>).
RELAY_SELF_URL=wss://203.0.113.7.sslip.io

# СОСЕДИ (peers) — здесь указываете уже работающий релей, чтобы влиться в сеть.
# Через запятую можно несколько.
#   • ПЕРВЫЙ релей в сети — оставьте ПУСТЫМ (ему не к кому подключаться).
#   • Каждый следующий — впишите адрес любого живого релея.
RELAY_PEERS=wss://89.108.83.230.sslip.io

# --- Звонки (ОБЯЗАТЕЛЬНО) ----------------------------------------------------
# TURN встроен в контейнер relay. Задайте ТОЛЬКО публичный IP сервера:
#   TURN_HOST — публичный IP сервера (БЕЗ .sslip.io), напр. 203.0.113.7
# TURN_SECRET больше НЕ нужен: релей сам генерирует и хранит его в data-томе
# (0600) и пишет конфиг coturn — секрета нет в env/аргументах/логах.
# Откройте в firewall: 3478/tcp, 3478/udp и 49160-49200/udp.
TURN_HOST=203.0.113.7

# --- Необязательно (безопасность/эксплуатация) -------------------------------
# Всё можно оставить пустым — релей работает в мягком режиме по умолчанию.
#
# Общий токен HTTP-gossip МЕЖДУ ВАШИМИ релеями. Без него анонимный HTTP-gossip
# выключен (безопасно); узлы всё равно находят друг друга через pull-gossip.
RELAY_GOSSIP_TOKEN=
# Токен для эндпоинта /metrics. Без него /metrics открыт всем.
RELAY_METRICS_TOKEN=
# Байтовый потолок очереди недоставленного (по умолчанию 8 ГБ). Поднимите под диск.
RELAY_MAX_QUEUE_BYTES=8589934592
